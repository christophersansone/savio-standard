---
import '@fontsource-variable/source-serif-4';
import '@fontsource-variable/source-sans-3';
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/600.css';
import '@fontsource/cormorant-garamond/700.css';
import '../styles/global.css';
import { REPO_URL } from '../lib/registry';

interface Props {
  title?: string;
  description?: string;
  /** OpenGraph type: 'website' for landing/index pages, 'article' for documents */
  type?: 'website' | 'article';
}

const {
  title = 'The Savio Standard',
  description = 'A parent-led movement to rebuild culture in Catholic grade schools.',
  type = 'website',
} = Astro.props;

const pageTitle = title === 'The Savio Standard' ? title : `${title} · The Savio Standard`;
const path = Astro.url.pathname;
const canonical = new URL(path, Astro.site);
const ogImage = new URL('/og.png', Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: 'The Savio Standard',
      url: Astro.site?.toString(),
      logo: new URL('/favicon.svg', Astro.site).toString(),
      description,
    },
    {
      '@type': 'WebSite',
      name: 'The Savio Standard',
      url: Astro.site?.toString(),
    },
  ],
};

const nav = [
  { href: '/plan', label: 'The Plan' },
  { href: '/manifesto', label: 'Manifesto' },
  { href: '/covenant', label: 'Covenant' },
  { href: '/protocol', label: 'Protocol' },
  { href: '/library', label: 'Library' },
];

const isActive = (href: string) => path === href || path.startsWith(href + '/');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap.xml" />
    <meta property="og:site_name" content="The Savio Standard" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="The Savio Standard — The Golden Rule is the standard, not the goal." />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body class="min-h-screen flex flex-col">
    <div class="h-[3px] bg-gradient-to-r from-gold-soft via-gold to-gold-soft"></div>

    <header class="border-b border-line bg-paper/90 backdrop-blur sticky top-0 z-10">
      <div class="mx-auto max-w-5xl px-5 py-4 flex items-center justify-between gap-6 relative">
        <a href="/" class="font-display text-2xl font-semibold tracking-wide text-ink-deep whitespace-nowrap">
          The Savio Standard
        </a>

        <nav class="hidden md:flex font-sans text-[0.8rem] font-semibold tracking-[0.14em] uppercase flex-wrap gap-x-5 gap-y-1 items-baseline">
          {
            nav.map((item) => (
              <a
                href={item.href}
                class:list={[
                  'transition-colors hover:text-gold',
                  isActive(item.href) ? 'text-gold' : 'text-ink-soft',
                ]}
              >
                {item.label}
              </a>
            ))
          }
          <a href={REPO_URL} class="text-ink-soft hover:text-gold transition-colors" title="GitHub repository">
            GitHub
          </a>
        </nav>

        <button
          id="nav-toggle"
          type="button"
          class="md:hidden -mr-1.5 p-1.5 text-ink-deep hover:text-gold transition-colors"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Open menu"
        >
          <svg id="icon-hamburger" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" class="size-6">
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
          <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" class="size-6 hidden">
            <line x1="5" y1="5" x2="19" y2="19"></line>
            <line x1="19" y1="5" x2="5" y2="19"></line>
          </svg>
        </button>

        <nav
          id="mobile-menu"
          class="md:hidden absolute right-5 top-full mt-2 w-56 origin-top-right rounded-lg border border-line bg-paper shadow-lg py-2 flex flex-col font-sans text-[0.8rem] font-semibold tracking-[0.14em] uppercase opacity-0 scale-95 pointer-events-none transition duration-150 ease-out z-20"
        >
          {
            nav.map((item) => (
              <a
                href={item.href}
                class:list={[
                  'px-4 py-2 transition-colors hover:text-gold hover:bg-paper-deep',
                  isActive(item.href) ? 'text-gold' : 'text-ink-soft',
                ]}
              >
                {item.label}
              </a>
            ))
          }
          <a href={REPO_URL} class="px-4 py-2 text-ink-soft hover:text-gold hover:bg-paper-deep transition-colors" title="GitHub repository">
            GitHub
          </a>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-line bg-paper-deep mt-20">
      <div class="mx-auto max-w-5xl px-5 py-10 font-sans text-sm text-ink-soft">
        <div class="ornament mb-6 text-gold">✦</div>
        <div class="grid gap-8 sm:grid-cols-3">
          <div>
            <p class="font-display text-lg text-ink-deep mb-1">The Savio Standard</p>
            <p class="italic font-serif">
              A lay movement under the patronage of St.&nbsp;Dominic&nbsp;Savio and St.&nbsp;John&nbsp;Bosco.
            </p>
          </div>
          <div>
            <p class="eyebrow mb-2">Our promise</p>
            <p>
              Free for families, forever. Read the{' '}
              <a href="/commitment" class="underline decoration-gold-soft underline-offset-2 hover:text-gold">Stewardship Commitment</a>.
            </p>
          </div>
          <div>
            <p class="eyebrow mb-2">Built in the open</p>
            <p>
              Every document on this site lives in a public{' '}
              <a href={REPO_URL} class="underline decoration-gold-soft underline-offset-2 hover:text-gold">repository</a>{' '}
              — corrections and contributions welcome.
            </p>
          </div>
        </div>
        <p class="mt-8 text-xs text-ink-soft/80">
          Working draft · “The Savio Standard” is a working title · Content licensed{' '}
          <a href={`${REPO_URL}/blob/master/LICENSE.md`} class="underline underline-offset-2 hover:text-gold">CC BY-NC-SA 4.0</a>{' '}
          · © 2026 Savio Standard
        </p>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('nav-toggle');
      const menu = document.getElementById('mobile-menu');
      const iconHamburger = document.getElementById('icon-hamburger');
      const iconClose = document.getElementById('icon-close');

      if (toggle && menu && iconHamburger && iconClose) {
        const setOpen = (open: boolean) => {
          toggle.setAttribute('aria-expanded', String(open));
          toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
          menu.classList.toggle('opacity-100', open);
          menu.classList.toggle('scale-100', open);
          menu.classList.toggle('pointer-events-auto', open);
          menu.classList.toggle('opacity-0', !open);
          menu.classList.toggle('scale-95', !open);
          menu.classList.toggle('pointer-events-none', !open);
          iconHamburger.classList.toggle('hidden', open);
          iconClose.classList.toggle('hidden', !open);
        };

        toggle.addEventListener('click', () => {
          setOpen(toggle.getAttribute('aria-expanded') !== 'true');
        });

        document.addEventListener('click', (e) => {
          const target = e.target as Node;
          if (!menu.contains(target) && !toggle.contains(target)) setOpen(false);
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') setOpen(false);
        });

        menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));

        window.matchMedia('(min-width: 768px)').addEventListener('change', (e) => {
          if (e.matches) setOpen(false);
        });
      }
    </script>
  </body>
</html>
