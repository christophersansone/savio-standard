---
import { getEntry, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import { docs, REPO_URL } from '../lib/registry';

export function getStaticPaths() {
  return docs.map((d) => ({ params: { slug: d.slug }, props: { doc: d } }));
}

const { doc } = Astro.props;
const entry = await getEntry(doc.collection, doc.id);
if (!entry) throw new Error(`Missing entry: ${doc.collection}/${doc.id}`);
const { Content } = await render(entry);
---

<Base title={doc.title} description={doc.description} type="article">
  <article class="mx-auto max-w-3xl px-5 py-14">
    <header class="mb-10 border-b border-line pb-8">
      <p class="eyebrow mb-3">{doc.section}</p>
      <h1 class="font-display text-4xl sm:text-5xl font-semibold leading-tight text-ink-deep text-balance">
        {doc.title}
      </h1>
      <p class="mt-4 font-sans text-[0.95rem] leading-relaxed text-ink-soft max-w-2xl">{doc.description}</p>
      <p class="mt-4 font-sans text-xs uppercase tracking-[0.14em] text-ink-soft/70">
        Working draft ·
        <a
          href={`${REPO_URL}/blob/master/${doc.srcPath}`}
          class="text-gold hover:text-ink-deep transition-colors"
        >
          suggest an edit
        </a>
      </p>
    </header>

    <div class="prose prose-savio prose-lg max-w-none">
      <Content />
    </div>
  </article>
</Base>
